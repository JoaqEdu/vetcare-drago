// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== ENUMS ====================

enum UserRole {
  ADMIN
  VET
  ASSISTANT
}

enum Species {
  DOG
  CAT
  BIRD
  RABBIT
  HAMSTER
  FISH
  REPTILE
  OTHER
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum AppointmentType {
  CHECKUP
  VACCINATION
  DEWORMING
  SURGERY
  EMERGENCY
  GROOMING
  DENTAL
  LABORATORY
  XRAY
  FOLLOWUP
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

enum NotificationType {
  APPOINTMENT_REMINDER
  VACCINATION_DUE
  DEWORMING_DUE
  GENERAL
}

enum TreatmentStatus {
  ACTIVE
  COMPLETED
}

// ==================== MODELS ====================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          UserRole @default(VET)
  phone         String?
  isActive      Boolean  @default(true)

  appointments  Appointment[]
  medicalRecords MedicalRecord[]
  notifications Notification[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Owner {
  id               String   @id @default(cuid())
  firstName        String
  lastName         String
  email            String?  @unique
  phone            String
  address          String?
  alternatePhone   String?
  city             String?
  notes            String?

  portalEnabled    Boolean  @default(false)
  portalToken      String?  @unique
  lastLoginAt      DateTime?

  isActive         Boolean  @default(true)

  patients         Patient[]
  notifications    Notification[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([phone])
}
model Patient {
  id            String   @id @default(cuid())
  name          String
  species       Species  @default(DOG)
  breed         String?
  gender        Gender   @default(UNKNOWN)
  birthDate     DateTime?
  weight        Float?
  color         String?
  chipNumber    String?
  notes         String?

  isActive        Boolean      @default(true)
  isDeceased      Boolean      @default(false)
  deceasedAt      DateTime?

  ownerId       String
  owner         Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  appointments  Appointment[]
  vaccinations  Vaccination[]
  dewormings    Deworming[]
  dentalRecords DentalRecord[]
  labResults    LabResult[]
  xrayRecords   XRayRecord[]
  medicalRecords MedicalRecord[]
  notifications   Notification[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Appointment {
  id            String            @id @default(cuid())
  scheduledAt   DateTime
  duration      Int               @default(30)
  reason        String?
  type          AppointmentType   @default(CHECKUP)
  status        AppointmentStatus @default(SCHEDULED)
  notes         String?

  // Campos para citas de vacunación
  vaccineName         String?
  vaccineType         String?
  vaccineManufacturer String?

  patientId     String
  patient       Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)

  vetId         String
  vet           User              @relation(fields: [vetId], references: [id], onDelete: Cascade)

  medicalRecord    MedicalRecord?
  dentalRecord     DentalRecord?
  vaccination      Vaccination?
  deworming        Deworming?
  labResult        LabResult?
  xrayRecord       XRayRecord?

  // Follow-up relationship
  parentRecordId   String?
  parentRecord     MedicalRecord?  @relation("RecordFollowUps", fields: [parentRecordId], references: [id], onDelete: SetNull)

  notifications Notification[]

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([scheduledAt])
  @@index([status])
  @@index([type])
  @@index([parentRecordId])
}

model Vaccination {
  id              String   @id @default(cuid())
  vaccineName     String
  vaccineType     String?
  manufacturer    String?
  batchNumber     String?

  administeredAt  DateTime @default(now())
  nextDueDate     DateTime?

  // Siguiente vacuna
  nextVaccineName String?
  isBooster       Boolean  @default(false)

  notes           String?

  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  appointmentId   String?  @unique
  appointment     Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
  @@index([nextDueDate])
}

model Deworming {
  id              String   @id @default(cuid())
  productName     String   // Nombre del desparasitante
  productType     String?  // Interno, Externo, Ambos
  manufacturer    String?
  dose            String?  // Dosis aplicada (ej: "5ml", "1 tableta")

  weight          Float?   // Peso del animal al momento de la aplicación
  administeredAt  DateTime @default(now())
  nextDueDate     DateTime?

  // Siguiente desparasitación
  nextDewormingType String?  // Tipo de siguiente desparasitación

  notes           String?

  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  appointmentId   String?  @unique
  appointment     Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
  @@index([nextDueDate])
}

model DentalRecord {
  id              String   @id @default(cuid())
  procedure       String   // Limpieza, Extracción, Tratamiento, etc.
  teethAffected   String?  // Dientes afectados o tratados
  findings        String?  // Hallazgos durante el procedimiento
  treatment       String?  // Tratamiento realizado
  anesthesia      Boolean  @default(false)
  nextCheckup     DateTime?

  notes           String?

  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  appointmentId   String?  @unique
  appointment     Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  performedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
}

model LabResult {
  id              String   @id @default(cuid())
  testType        String   // Tipo de análisis (Hemograma, Bioquímica, Urianálisis, etc.)
  testName        String?  // Nombre específico del test
  results         String   // Resultados del laboratorio (texto largo)
  interpretation  String?  // Interpretación del veterinario
  laboratory      String?  // Laboratorio externo (si aplica)
  referenceValues String?  // Valores de referencia

  attachmentUrl   String?  // URL del archivo PDF/imagen del resultado

  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  appointmentId   String?  @unique
  appointment     Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  sampleDate      DateTime @default(now())
  resultDate      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
}

model XRayRecord {
  id              String   @id @default(cuid())
  bodyPart        String   // Parte del cuerpo radiografiada
  views           String?  // Vistas tomadas (lateral, ventrodorsal, etc.)
  findings        String   // Hallazgos radiográficos
  diagnosis       String?  // Diagnóstico basado en la radiografía
  imageUrl        String?  // URL de la imagen de rayos X

  notes           String?

  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  appointmentId   String?  @unique
  appointment     Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  performedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
}

model MedicalRecord {
  id               String       @id @default(cuid())
  visitDate        DateTime     @default(now())

  // Chief complaint and history
  chiefComplaint   String?
  presentIllness   String?

  // Physical exam
  weight           Float?
  temperature      Float?
  heartRate        Int?
  respiratoryRate  Int?

  // Assessment
  diagnosis        String?
  differentialDx   String?
  prognosis        String?

  // Plan
  treatment        String?
  recommendations  String?
  followUpDate     DateTime?

  // Notes
  internalNotes    String?

  // Follow-up tracking
  requiresFollowUp Boolean          @default(false)
  treatmentStatus  TreatmentStatus?

  patientId        String
  patient          Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  vetId            String
  vet              User         @relation(fields: [vetId], references: [id], onDelete: Cascade)

  appointmentId    String?      @unique
  appointment      Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  followUpAppointments Appointment[] @relation("RecordFollowUps")

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([patientId])
  @@index([vetId])
  @@index([visitDate])
}

model Notification {
  id          String             @id @default(cuid())
  title       String
  type        NotificationType
  message     String
  channel     NotificationChannel @default(IN_APP)
  status      NotificationStatus  @default(PENDING)

  ownerId     String?
  owner       Owner?             @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  userId      String?
  user        User?              @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointmentId String?
  appointment Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  patientId       String?
  patient         Patient?            @relation(fields: [patientId], references: [id], onDelete: SetNull)

  scheduledFor DateTime?
  sentAt       DateTime?
  readAt       DateTime?

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status])
  @@index([scheduledFor])
}

