// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===================== ENUMS ====================

enum UserRole {
  ADMIN
  VET
  ASSISTANT
}

enum Species {
  DOG
  CAT
  BIRD
  RABBIT
  HAMSTER
  FISH
  REPTILE
  OTHER
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum AppointmentType {
  CHECKUP
  VACCINATION
  SURGERY
  EMERGENCY
  GROOMING
  DENTAL
  LABORATORY
  XRAY
  FOLLOWUP
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

enum NotificationType {
  APPOINTMENT_REMINDER
  VACCINATION_DUE
  LOW_STOCK
  INVOICE_OVERDUE
  GENERAL
}

// ==================== MODELS ====================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          UserRole @default(VET)
  phone         String?
  isActive      Boolean  @default(true)

  appointments  Appointment[]
  medicalRecords MedicalRecord[]
  notifications Notification[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Owner {
  id               String   @id @default(cuid())
  firstName        String
  lastName         String
  email            String?  @unique
  phone            String
  address          String?

  portalEnabled    Boolean  @default(false)
  portalToken      String?  @unique
  lastLoginAt      DateTime?

  isActive         Boolean  @default(true)

  patients         Patient[]
  notifications    Notification[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([phone])
}
model Patient {
  id            String   @id @default(cuid())
  name          String
  species       Species  @default(DOG)
  breed         String?
  gender        Gender   @default(UNKNOWN)
  birthDate     DateTime?
  weight        Float?
  color         String?
  notes         String?

  isActive        Boolean      @default(true)
  isDeceased      Boolean      @default(false)
  deceasedAt      DateTime?

  ownerId       String
  owner         Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  appointments  Appointment[]
  vaccinations  Vaccination[]
  medicalRecords MedicalRecord[]
  notifications   Notification[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Appointment {
  id            String            @id @default(cuid())
  scheduledAt   DateTime
  duration      Int               @default(30)
  reason        String?
  type          AppointmentType   @default(CHECKUP)
  status        AppointmentStatus @default(SCHEDULED)
  notes         String?

  patientId     String
  patient       Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)

  vetId         String
  vet           User              @relation(fields: [vetId], references: [id], onDelete: Cascade)

  medicalRecord    MedicalRecord?

  notifications Notification[]

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([scheduledAt])
  @@index([status])
  @@index([type])
}

model Vaccination {
  id              String   @id @default(cuid())
  vaccineName     String
  vaccineType     String?
  manufacturer    String?
  batchNumber     String?

  administeredAt  DateTime @default(now())
  nextDueDate     DateTime?

  notes           String?

  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
  @@index([nextDueDate])
}

model MedicalRecord {
  id               String       @id @default(cuid())
  visitDate        DateTime     @default(now())

  // Chief complaint and history
  chiefComplaint   String?
  presentIllness   String?

  // Physical exam
  weight           Float?
  temperature      Float?
  heartRate        Int?
  respiratoryRate  Int?

  // Assessment
  diagnosis        String?
  differentialDx   String?
  prognosis        String?

  // Plan
  treatment        String?
  recommendations  String?
  followUpDate     DateTime?

  // Notes
  internalNotes    String?

  patientId        String
  patient          Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  vetId            String
  vet              User         @relation(fields: [vetId], references: [id], onDelete: Cascade)

  appointmentId    String?      @unique
  appointment      Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([patientId])
  @@index([vetId])
  @@index([visitDate])
}

model Notification {
  id          String             @id @default(cuid())
  title       String
  type        NotificationType
  message     String
  channel     NotificationChannel @default(IN_APP)
  status      NotificationStatus  @default(PENDING)

  ownerId     String?
  owner       Owner?             @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  userId      String?
  user        User?              @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointmentId String?
  appointment Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  patientId       String?
  patient         Patient?            @relation(fields: [patientId], references: [id], onDelete: SetNull)

  scheduledFor DateTime?
  sentAt       DateTime?
  readAt       DateTime?

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status])
  @@index([scheduledFor])
}

